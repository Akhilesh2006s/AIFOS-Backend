# Server
PORT=3001
NODE_ENV=development
TRUST_PROXY_HOPS=1

# MongoDB Atlas — must start with mongodb:// or mongodb+srv:// (no quotes in Railway)
# SRV (Railway/Linux): mongodb+srv://USER:PASSWORD@cluster0.eiramxt.mongodb.net/AFIOS?appName=Cluster0
# Standard (Windows dev): mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/AFIOS?ssl=true&authSource=admin&retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.eiramxt.mongodb.net/AFIOS?appName=Cluster0
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5

# JWT (required in production — min 32 characters)
JWT_SECRET=change-this-to-a-long-random-secret-in-production-min-32-chars
JWT_EXPIRES_IN=8h

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_PER_MIN=120

# Account lockout (brute-force protection)
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Security & feature gates
ALLOW_PUBLIC_REGISTRATION=false
ENABLE_SWAGGER=false
SEED_DEMO=false
# Startup seeding: off in production unless ENABLE_STARTUP_SEED=true
ENABLE_STARTUP_SEED=
# Bulk Bekem enterprise demo (500+ vendors, etc.) — only when explicitly true
SEED_ENTERPRISE=false

# HTTP delivery (integrations, webhooks, ERP/comm adapters)
HTTP_DELIVERY_TIMEOUT_MS=30000

# Admin seed (created on first boot if no users exist)
# Use a strong password meeting policy: 12+ chars, upper, lower, number, special
SEED_ADMIN_EMAIL=admin@afios.com
SEED_ADMIN_PASSWORD=ChangeMe!Admin2026
SEED_ADMIN_NAME=AFIOS Administrator
